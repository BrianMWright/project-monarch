name: "Mobile Build"

on:
  push:
    branches: ["main"]
  workflow_dispatch:

env:
  GODOT_VERSION: "4.6.2"
  PROJECT_PATH: "src/monarch-game"
  EXPORT_NAME: "MonarchGame"
  ANDROID_HOME: /opt/android-sdk

jobs:
  export-android:
    name: Android (.apk)
    runs-on: ubuntu-latest

    container:
      image: docker.io/barichello/godot-ci:4.6.2

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v5
  
      - name: Setup Godot paths
        run: |
          mkdir -p "${HOME}/.local/share/godot/export_templates"
          mkdir -p "${HOME}/.config/godot"

          if [ -d "/root/.local/share/godot/export_templates/${GODOT_VERSION}.stable" ]; then
            cp -r "/root/.local/share/godot/export_templates/${GODOT_VERSION}.stable" \
              "${HOME}/.local/share/godot/export_templates/${GODOT_VERSION}.stable"
          fi

          if [ -f /root/.config/godot/editor_settings-4.6.tres ]; then
            cp /root/.config/godot/editor_settings-4.6.tres "${HOME}/.config/godot/editor_settings-4.6.tres"
          fi

          if [ -f /root/.config/godot/editor_settings-4.tres ]; then
            cp /root/.config/godot/editor_settings-4.tres "${HOME}/.config/godot/editor_settings-4.tres"
          fi

          echo "=== TEMPLATE CHECK ==="
          ls -la "${HOME}/.local/share/godot/export_templates/${GODOT_VERSION}.stable" || true
      
      - name: Copy Export Templates from Image
        run: |
          mkdir -p "${HOME}/.local/share/godot/export_templates"
          if [ -d "/root/.local/share/godot/export_templates/${GODOT_VERSION}.stable" ]; then
            cp -r "/root/.local/share/godot/export_templates/${GODOT_VERSION}.stable" \
              "${HOME}/.local/share/godot/export_templates/${GODOT_VERSION}.stable"
          fi
          echo "Templates copied:"
          ls "${HOME}/.local/share/godot/export_templates/${GODOT_VERSION}.stable/" | head -5

      - name: Install Android SDK & Java
        run: |
          apt-get update
          apt-get install -y openjdk-17-jdk-headless python3 wget unzip libfontconfig1

          # Detect JAVA_HOME dynamically instead of hardcoding
          DETECTED_JAVA_HOME=$(dirname $(dirname $(readlink -f $(which javac))))
          echo "Detected JAVA_HOME: ${DETECTED_JAVA_HOME}"
          echo "JAVA_HOME=${DETECTED_JAVA_HOME}" >> $GITHUB_ENV
          export JAVA_HOME="${DETECTED_JAVA_HOME}"

          # Install Android command-line tools
          mkdir -p "${ANDROID_HOME}/cmdline-tools"
          wget -q "https://dl.google.com/android/repository/commandlinetools-linux-11076708_latest.zip" \
            -O /tmp/cmdline-tools.zip
          unzip -q /tmp/cmdline-tools.zip -d /tmp/cmdline-extract
          mv /tmp/cmdline-extract/cmdline-tools "${ANDROID_HOME}/cmdline-tools/latest"
          yes | "${ANDROID_HOME}/cmdline-tools/latest/bin/sdkmanager" --licenses > /dev/null 2>&1
          "${ANDROID_HOME}/cmdline-tools/latest/bin/sdkmanager" \
            "build-tools;35.0.1" "platforms;android-35" "platform-tools"

      - name: Setup Keystores
        run: |
          mkdir -p "${HOME}/.android"
          keytool -genkey -v \
            -keystore "${HOME}/.android/debug.keystore" \
            -alias androiddebugkey \
            -storepass android -keypass android \
            -keyalg RSA -keysize 2048 -validity 10000 \
            -dname "CN=Android Debug,O=Android,C=US"
          echo "${{ secrets.SECRET_RELEASE_KEYSTORE_BASE64 }}" | base64 -d > "${PROJECT_PATH}/release.keystore"

      - name: Inject Keystore Credentials
        env:
          _KEY_ALIAS: ${{ secrets.SECRET_RELEASE_KEYSTORE_USER }}
          _KEY_PASS: ${{ secrets.SECRET_RELEASE_KEYSTORE_PASSWORD }}
        run: |
          python3 - <<'PYEOF'
          import os
          cfg = os.path.join(os.environ['PROJECT_PATH'], 'export_presets.cfg')
          with open(cfg) as f:
              text = f.read()
          text = text.replace('CI_KEY_ALIAS', os.environ.get('_KEY_ALIAS', ''))
          text = text.replace('CI_KEY_PASS', os.environ.get('_KEY_PASS', ''))
          with open(cfg, 'w') as f:
              f.write(text)
          PYEOF

      - name: Import Godot Project
        run: |
          godot --headless --path "${PROJECT_PATH}" --import 2>&1 | tee /tmp/godot-import.log || true

      - name: Start ADB daemon
        run: |
          export PATH="${ANDROID_HOME}/platform-tools:${PATH}"
          adb start-server
          adb devices
      
      - name: Write Godot Editor Settings
        run: |
          mkdir -p "${HOME}/.config/godot"
          { printf '[gd_resource type="EditorSettings" format=3]\n\n[resource]\n'
            printf 'export/android/android_sdk_path = "%s"\n' "${ANDROID_HOME}"
            printf 'export/android/java_sdk_path = "%s"\n' "${JAVA_HOME}"
            printf 'export/android/debug_keystore = "%s/.android/debug.keystore"\n' "${HOME}"
            printf 'export/android/debug_keystore_user = "androiddebugkey"\n'
            printf 'export/android/debug_keystore_pass = "android"\n'
          } > "${HOME}/.config/godot/editor_settings-4.6.tres"

      - name: Pre-export Diagnostics
        run: |
          echo "=== Godot Version ==="
          godot --version 2>/dev/null || echo "Could not get version"
          echo ""
          echo "=== Export Templates ==="
          ls "${HOME}/.local/share/godot/export_templates/${GODOT_VERSION}.stable/" 2>/dev/null | head -5 || echo "MISSING"
          echo ""
          echo "=== JAVA_HOME ==="
          echo "JAVA_HOME=${JAVA_HOME}"
          test -f "${JAVA_HOME}/bin/javac" && echo "javac: OK" || echo "javac: MISSING"
          test -f "${JAVA_HOME}/bin/jarsigner" && echo "jarsigner: OK" || echo "jarsigner: MISSING"
          echo ""
          echo "=== Android SDK ==="
          echo "ANDROID_HOME=${ANDROID_HOME}"
          test -f "${ANDROID_HOME}/build-tools/35.0.1/aapt2" && echo "aapt2: OK" || echo "aapt2: MISSING"
          test -f "${ANDROID_HOME}/build-tools/35.0.1/d8" && echo "d8: OK" || echo "d8: MISSING"
          test -f "${ANDROID_HOME}/build-tools/35.0.1/zipalign" && echo "zipalign: OK" || echo "zipalign: MISSING"
          test -f "${ANDROID_HOME}/build-tools/35.0.1/apksigner" && echo "apksigner: OK" || echo "apksigner: MISSING"
          test -f "${ANDROID_HOME}/platform-tools/adb" && echo "adb: OK" || echo "adb: MISSING"
          test -d "${ANDROID_HOME}/platforms/android-35" && echo "platform-35: OK" || echo "platform-35: MISSING"
          echo ""
          echo "=== Editor Settings ==="
          cat "${HOME}/.config/godot/editor_settings-4.6.tres"
          echo ""
          echo "=== Keystores ==="
          test -f "${HOME}/.android/debug.keystore" && echo "Debug: OK" || echo "Debug: MISSING"
          if [ -f "${PROJECT_PATH}/release.keystore" ]; then
            SIZE=$(wc -c < "${PROJECT_PATH}/release.keystore")
            echo "Release: OK (${SIZE} bytes)"
            keytool -list -keystore "${PROJECT_PATH}/release.keystore" -storepass changeit 2>&1 | head -5 || true
          else
            echo "Release: MISSING"
          fi
          echo ""
          echo "=== Export Preset (critical fields) ==="
          grep -E "^(keystore/|gradle_build/|package/signed|package/export_format)" "${PROJECT_PATH}/export_presets.cfg" | head -20

      
      - name: Verify preset
        run: |
          echo "=== VERIFY PRESET ==="
          sed -n '/\[preset\.0\]/,/\[preset\.1\]/p' "${PROJECT_PATH}/export_presets.cfg"
      
      - name: Export Android APK
        run: |
          mkdir -p build/android
          godot --headless --verbose \
            --path "${PROJECT_PATH}" \
            --export-release "Android" \
            "build/android/${EXPORT_NAME}.apk" \
            2>&1 | tee /tmp/godot-export.log
          if [ ! -f "build/android/${EXPORT_NAME}.apk" ]; then
            echo "ERROR: APK was not produced"
            exit 1
          fi

      - name: Upload Godot Logs
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: godot-export-logs
          path: |
            /tmp/godot-import.log
            /tmp/godot-export.log
          retention-days: 7

      - name: Upload APK Artifact
        if: success()
        uses: actions/upload-artifact@v4
        with:
          name: monarchgame-android-apk
          path: build/android/${{ env.EXPORT_NAME }}.apk
          retention-days: 30
